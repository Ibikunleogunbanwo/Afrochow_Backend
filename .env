# ==============================================================================
# AFROCHOW APPLICATION - ENVIRONMENT VARIABLES (LOCAL DEV)
# ==============================================================================
# IMPORTANT:
# 1. This file is loaded by DotenvConfig at startup (local dev only)
# 2. Railway injects env vars directly — this file is NOT used in production
# 3. NEVER commit this file to version control (.gitignore must include .env)
# ==============================================================================

# ==============================================================================
# SPRING PROFILE
# ==============================================================================
# Options: dev, prod
SPRING_PROFILES_ACTIVE=dev

# ==============================================================================
# DATABASE CONFIGURATION - MySQL (Local)
# ==============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=afrochowdb
DB_USERNAME=Superadmin
DB_PASSWORD=9AgSt2b+1tsNtanEKAMgyA==

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================
APP_JWT_SECRET=REDACTED_JWT_SECRET
APP_JWT_ENCRYPTION_KEY=REDACTED_JWT_ENC_KEY
# 1 hour in ms
APP_JWT_EXPIRATION=3600000
# 7 days in ms
APP_JWT_REFRESH_EXPIRATION=604800000
APP_TOKEN_SECRET=REDACTED_TOKEN_SECRET

# ==============================================================================
# SECURITY / ACCOUNT LOCKOUT
# ==============================================================================
SECURITY_MAX_LOGIN_ATTEMPTS=5
# in minutes
SECURITY_LOCKOUT_DURATION=15
# days to retain old login attempts
SECURITY_CLEANUP_DAYS=30

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173,http://10.0.0.149:3000

# ==============================================================================
# EMAIL CONFIGURATION (Resend SMTP relay — same provider as production)
# ==============================================================================
SPRING_MAIL_ENABLED=true

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
# Resend requires the literal string "resend" as the username
SMTP_USERNAME=resend
# Your Resend API key (re_xxxxxxxxx)
SMTP_PASSWORD=REDACTED_RESEND_KEY
# Must be a verified sender in your Resend account
SMTP_FROM=onboarding@resend.dev

# ==============================================================================
# APPLICATION INFO
# ==============================================================================
APP_NAME=Afrochow
APP_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:3000

# ==============================================================================
# FILE UPLOAD CONFIGURATION
# ==============================================================================
APP_UPLOAD_DIR=/Users/ayoogunbanwo/afrochow-uploads
# 10MB in bytes
APP_UPLOAD_MAX_FILE_SIZE=10485760

# ==============================================================================
# NOTES
# ==============================================================================
# 1. Resend free tier: 3,000 emails/month, 100/day
# 2. SMTP_USERNAME must be the literal string "resend" (not your email)
# 3. SMTP_PASSWORD is your Resend API key starting with re_
# 4. To send from your own address, verify a sender in resend.com dashboard
# 5. Never commit this .env file to GitHub
