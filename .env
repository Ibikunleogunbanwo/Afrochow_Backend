# ==============================================================================
# AFROCHOW APPLICATION - ENVIRONMENT VARIABLES
# ==============================================================================
# IMPORTANT:
# 1. Copy this file to .env (NOT tracked in git)
# 2. Replace placeholder values with actual credentials
# 3. NEVER commit .env to version control
# ==============================================================================

# ==============================================================================
# SPRING PROFILE
# ==============================================================================
# Options: dev, staging, prod
SPRING_PROFILE=dev

# ==============================================================================
# DATABASE CONFIGURATION - MySQL
# ==============================================================================
# Dev Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=afrochowdb
DB_USERNAME=Superadmin
DB_PASSWORD=9AgSt2b+1tsNtanEKAMgyA==

# Prod Database
PROD_DB_HOST=prod-db.afrochow.ca
PROD_DB_PORT=3306
PROD_DB_NAME=afrochow_prod
PROD_DB_USERNAME=afrochow_user
PROD_DB_PASSWORD=StrongProdPass123!

# MySQL specific settings
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_DIALECT=org.hibernate.dialect.MySQL8Dialect
DB_USE_SSL=false
DB_USE_UNICODE=true
DB_CHARACTER_ENCODING=utf8mb4
DB_SERVER_TIMEZONE=UTC

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================
APP_JWT_ENCRYPTION_KEY=TmHng3W1UZe5C+21uuPNLWn2rzsXU4Gm5xJYpHrJtJw=
APP_JWT_SECRET=1vJSm6UaayovBHUa18noucHECFhuE5463xJlF0ZkllyamniTII20BL4HifLkmnB7C6mPGzUbCLHWnsGDyYqlIA==
APP_JWT_EXPIRATION=3600000# 1 hour in ms
APP_JWT_REFRESH_EXPIRATION=604800000#
APP_TOKEN_SECRET=BiySDDZy8Nm8BA9b02F7YYknLgzxZAhFhGPM7L/7cj4U3A7PGxGHHzI9XujtDVrhXnmwrwL1GyjjK7gDsBJmxQ==

# ==============================================================================
# BCRYPT CONFIGURATION
# ==============================================================================
BCRYPT_STRENGTH=12

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://10.0.0.149:3000,https://afrochow.ca,https://www.afrochow.ca

# ==============================================================================
# ACCOUNT LOCKOUT CONFIGURATION
# ==============================================================================
SECURITY_MAX_LOGIN_ATTEMPTS=5
SECURITY_LOCKOUT_DURATION=15# in minutes
SECURITY_CLEANUP_DAYS=30# old login attempts retention

# ==============================================================================
# SWAGGER / API DOCUMENTATION
# ==============================================================================
SWAGGER_ENABLED=true

# ==============================================================================
# EMAIL CONFIGURATION
# ==============================================================================
SPRING_MAIL_ENABLED=true
EMAIL_PROVIDER=GMAIL# Options: GMAIL, SENDGRID

# Gmail (development)
DEV_GMAIL_HOST=smtp.gmail.com
DEV_GMAIL_PORT=587
DEV_GMAIL_USERNAME=rapidstylers@gmail.com
DEV_GMAIL_PASSWORD=egilyjchiztopwpo#
DEV_GMAIL_FROM=rapidstylers@gmail.com

# SendGrid (production)
PROD_SENDGRID_HOST=smtp.sendgrid.net
PROD_SENDGRID_PORT=587
PROD_SENDGRID_USERNAME=apikey# literal string 'apikey'
PROD_SENDGRID_PASSWORD=SG.yourapikey#

# App info
APP_NAME=Afrochow
APP_URL=http://localhost:8080

# ==============================================================================
# FILE UPLOAD CONFIGURATION
# ==============================================================================
SPRING_SERVLET_MULTIPART_ENABLED=true
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB
SPRING_SERVLET_MULTIPART_FILE_SIZE_THRESHOLD=2KB

APP_UPLOAD_DIR=/Users/ayoogunbanwo/afrochow-uploads
APP_UPLOAD_MAX_FILE_SIZE=10485760# 10MB

# ==============================================================================
# NOTES
# ==============================================================================
# 1. For MySQL: Create database with: CREATE DATABASE afrochow CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# 2. For Gmail: Use App Passwords, not your Gmail password.
# 3. For SendGrid: username = "apikey" (literal), password = your API key.
# 4. Use SPRING_PROFILE=dev or prod to automatically switch database and email configs.
# 5. MySQL driver dependency required: mysql-connector-j
# 6. Never commit this .env file to GitHub.